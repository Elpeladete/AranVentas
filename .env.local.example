# Configuración de Odoo FSM
# Copia este archivo a .env.local y completa con tus credenciales

# URL de tu instancia de Odoo (sin barra al final)
# Ejemplo: https://tuempresa.odoo.com
NEXT_PUBLIC_ODOO_URL=

# Nombre de tu base de datos en Odoo
NEXT_PUBLIC_ODOO_DATABASE=

# Usuario de Odoo con permisos para FSM
NEXT_PUBLIC_ODOO_USERNAME=

# Contraseña del usuario de Odoo
NEXT_PUBLIC_ODOO_PASSWORD=

# API Key de Odoo (opcional, si usas REST API)
NEXT_PUBLIC_ODOO_API_KEY=

# Configuración de ImgBB (ya existente)
NEXT_PUBLIC_IMGBB_API_KEY=2f651ab1858afc2478cb3da0a3b12988
